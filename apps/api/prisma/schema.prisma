generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String             @id
  email        String             @unique
  name         String
  createdAt    DateTime           @default(now())
  credential   AuthCredential?
  profile      Profile?
  inventory    UserInventory?
  sessions     Session[]
  rosters      Roster[]
  friendshipsA Friendship[]       @relation("FriendshipRequester")
  friendshipsB Friendship[]       @relation("FriendshipAddressee")
  answers      PredictionAnswer[]
  results      PredictionResult[]
  xpLedger     XPTransaction[]
  unlocks      CosmeticUnlock[]
  leagueMemberships LeagueMember[]
}

model Profile {
  userId             String  @id
  username           String  @unique
  bio                String?
  favoriteTeamId     String?
  credits            Float   @default(100)
  xp                 Int     @default(0)
  level              Int     @default(1)
  streak             Int     @default(0)
  onboardingCompleted Boolean @default(false)
  equippedCosmetics  Json
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthCredential {
  userId       String   @id
  passwordHash String
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  token      String   @id
  userId     String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Friendship {
  id          String   @id
  requesterId String
  addresseeId String
  pairKey     String   @unique
  status      String
  createdAt   DateTime @default(now())
  requester   User     @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User     @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
}

model Invite {
  id         String   @id
  leagueId   String
  code       String   @unique
  createdBy  String
  createdAt  DateTime @default(now())
  expiresAt  DateTime?
}

model Team {
  id        String   @id
  name      String
  shortName String
  city      String
  players   Player[]
}

model Player {
  id               String  @id
  name             String
  teamId           String
  role             String
  credits          Float
  rating           Float
  nationality      String
  selectionPercent Float
  team             Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Match {
  id         String   @id
  homeTeamId String
  awayTeamId String
  startsAt   DateTime
  venue      String
  state      String
}

model Contest {
  id          String   @id
  name        String
  kind        String
  matchId     String
  leagueId    String?
  salaryCap   Float
  rosterRules Json
  iplRules    Json
  lockTime    DateTime
  rewards     Json
  league      League?  @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  rosters     Roster[]

  @@index([leagueId])
  @@index([matchId])
}

model League {
  id          String   @id
  name        String
  description String?
  visibility  String
  createdBy   String
  inviteCode  String   @unique
  bannerStyle String
  members     LeagueMember[]
  contests    Contest[]
}

model LeagueMember {
  leagueId  String
  userId    String
  joinedAt  DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([leagueId, userId])
  @@index([userId])
}

model Roster {
  id                  String   @id
  contestId           String
  userId              String
  players             Json
  captainPlayerId     String
  viceCaptainPlayerId String
  impactPlayerId      String?
  totalCredits        Float
  submittedAt         DateTime
  locked              Boolean
  hasUncappedPlayer   Boolean
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest             Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([contestId])
}

model FantasyScoreEvent {
  id        String   @id
  matchId    String
  playerId   String
  label      String
  points     Int
  createdAt  DateTime @default(now())

  @@index([matchId])
}

model LeaderboardEntry {
  id              String   @id
  contestId       String
  userId          String
  points          Float
  rank            Int
  previousRank    Int
  trend           String
  projectedPoints Float?

  @@index([contestId])
  @@unique([contestId, userId])
}

model PredictionQuestion {
  id               String             @id
  matchId          String
  prompt           String
  category         String
  options          Json
  locksAt          DateTime
  resolvesAt       DateTime
  state            String
  xpReward         Int
  badgeRewardId    String?
  cosmeticRewardId String?
  answers          PredictionAnswer[]
  results          PredictionResult[]
}

model PredictionAnswer {
  id          String             @id
  questionId  String
  userId      String
  optionId    String
  submittedAt DateTime
  question    PredictionQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
}

model PredictionResult {
  id                String             @id
  questionId        String
  userId            String
  correctOptionId   String
  awardedXp         Int
  awardedBadgeId    String?
  awardedCosmeticId String?
  streak            Int
  settledAt         DateTime
  question          PredictionQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
}

model CosmeticItem {
  id                String   @id
  name              String
  description       String
  category          String
  rarity            String
  themeToken        String
  gameplayAffecting Boolean  @default(false)
  transferable      Boolean  @default(false)
  redeemable        Boolean  @default(false)
  resaleValue       Float    @default(0)
  unlocks           CosmeticUnlock[]
}

model CosmeticUnlock {
  id         String       @id
  userId     String
  cosmeticId String
  source     String
  unlockedAt DateTime
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic   CosmeticItem @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)
}

model UserInventory {
  userId      String   @id
  cosmeticIds String[]
  badgeIds    String[]
  equipped    Json
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String   @id
  label       String
  description String
  category    String
  seasonId    String?
}

model XPTransaction {
  id          String   @id
  userId      String
  source      String
  amount      Int
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProviderState {
  id              String   @id
  status          String
  syncedAt        DateTime
  lastAttemptedAt DateTime @default(now())
}
